# Токен бота Telegram (получить у @BotFather)
BOT_TOKEN=

# ID канала (можно @username или числовой ID)
CHANNEL_ID=

# База данных (путь к файлу)
DATABASE_PATH=bot_data.db

# Тематика: ai (ИИ) или facts (история/астрономия/цитаты)
THEME=ai

# Название бренда на картинках (по умолч. из темы)
BRAND_NAME=

# Сколько новостей публиковать за один запуск
MAX_POSTS_PER_RUN=2

# Интервал между запусками в часах
SCHEDULE_INTERVAL_HOURS=3

# Секунды между постами (чтобы не флудить)
POST_DELAY_SECONDS=60

# Режим постов: image (только фото), video (только видео), mixed (случайно)
POST_MODE=mixed

# Длительность видео в секундах
VIDEO_DURATION=6

# Подбирать тематические картинки (Pexels/Unsplash) для фона постов
USE_THEMED_IMAGES=true

# API ключи для поиска изображений (опционально, без них picsum.photos)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# Instagram (опционально)
IG_USERNAME=
IG_PASSWORD=

# 2FA код для Instagram (если включена двухфакторка)
IG_2FA_CODE=

# Прокси для Instagram (формат: http://user:pass@host:port)
IG_PROXY=

# User-Agent для имитации устройства (если пусто — используется стандартный)
IG_USER_AGENT=
IG_DEVICE=
IG_LOCALE=ru_RU

# Количество попыток входа/публикации
IG_LOGIN_MAX_RETRIES=3
IG_POST_MAX_RETRIES=3
IG_RETRY_DELAY=10
IG_FEEDBACK_WAIT=300
